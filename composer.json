{
    "name": "rak200/caster",
    "description": "Type casting contracts and utilities for PHP 8.4+",
    "version": "1.1.0",
    "type": "library",
    "license": "MIT",
    "keywords": ["casting", "type-casting", "contracts", "interfaces", "php84"],
    "homepage": "https://github.com/rak200/caster",
    "authors": [
        {
            "name": "rak200",
            "email": "rak.ricardo@windowslive.com",
            "homepage": "https://github.com/rak200"
        }
    ],
    "support": {
        "issues": "https://github.com/rak200/caster/issues",
        "source": "https://github.com/rak200/caster"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/rak200/utils"
        }
    ],
    "require": {
        "php": "^8.4",
        "rak200/utils": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Rak200\\Caster\\": "src/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1",
        "phpstan/phpstan": "^2.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Rak200\\Caster\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "php -c \"A:\\Program Files\\php\\php.ini\" vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse"
    }
}
